			for _, p in ipairs(Players:GetPlayers()) do
				local char = p.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					char.HumanoidRootPart.Size = Vector3.new(2,2,1)
					char.HumanoidRootPart.CanCollide = true
				end
			end
		end)
		chat("⚠️ [XUE] System has been remotely deactivated by the Creator.")
		return
	end
end

if scriptDisabled then return end

-- CHANGE OWNER
if assigners[plr.Name] then

	local t = m:match("^xue%s+(.-)%s+control$")

	if t then

		local found = findPlayerByFuzzy(t)

		if found then

			parentPlayer = found

			chat("👑🛡️ [XUE] Parent = "..found.DisplayName)
		end

		return
	end
end

if plr ~= parentPlayer then
	return
end

-- BASIC
