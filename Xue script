	runCommand({type="idle"})
end

if m == "xue stop" then
	runCommand({type="stop"})
end

-- ATTACK
local a = m:match("^xue attack%s+(.+)$")

if a then

	local found = findPlayerByFuzzy(a)

	if found then
		runCommand({type="attack", target=found})
	else
		chat("⚠️ [XUE] Player not found")
	end
end

-- HEIGHT
local h = m:match("^xue height%s+(-?%d+)$")

if h then
	runCommand({
		type="height",
		val=tonumber(h)
	})
end

-- IMMUNE
