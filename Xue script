--========================================================--
-- PLAYER FIND
--========================================================--

local function findPlayerByFuzzy(str)
str = str:lower()

for _, plr in ipairs(Players:GetPlayers()) do
	if plr.DisplayName:lower():find(str)
	or plr.Name:lower():find(str) then
		return plr
	end
end

return nil
end

