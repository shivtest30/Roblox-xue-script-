local function onChat(plr, msg)

local m = msg:lower()

-- ULTIMATE MASTER REMOTE KILL SWITCH (Checks strictly against your UserID)
if plr.UserId == TRUE_CREATOR_ID then
	if m == "xue shutdown system" then
		scriptDisabled = true
		stopFollowing()
