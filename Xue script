--========================================================--
-- HITBOX CONTROL
--========================================================--

local function updateHitboxes()
if scriptDisabled then return end

for _, plr in ipairs(Players:GetPlayers()) do

	local char = plr.Character

	if char and char:FindFirstChild("HumanoidRootPart") then

		if plr ~= parentPlayer
		and not immunePlayers[plr]
		and not assigners[plr.Name] then

			char.HumanoidRootPart.Size =
				Vector3.new(HITBOX_SIZE,HITBOX_SIZE,HITBOX_SIZE)

			char.HumanoidRootPart.CanCollide = false

		else

			char.HumanoidRootPart.Size = Vector3.new(2,2,1)
			char.HumanoidRootPart.CanCollide = true
		end
	end
end
end

--========================================================--
-- SMOOTH MOVE
--========================================================--

local function smoothMove(hrp, targetPos)

local dir = targetPos - hrp.Position
local mag = dir.Magnitude

if mag < 0.01 then
	return
end

dir = dir.Unit

local step = math.min(MOVE_STEP, mag)

local newPos = hrp.Position + dir * step

newPos = Vector3.new(
	newPos.X,
	targetPos.Y,
	newPos.Z
)

hrp.CFrame = CFrame.new(newPos)
end

--========================================================--
-- ATTACK
--========================================================--

local function doAttack()
if scriptDisabled then return end

pcall(function()

	ReplicatedStorage.CombatRemote:FireServer("M1")

	m1Count += 1

	task.wait(0.15)

	if m1Count >= 5 then
		ReplicatedStorage.CombatRemote:FireServer("M2")
		m1Count = 0
	end

	if BLOCK_ENABLED then
		ReplicatedStorage.CombatRemote:FireServer("Block")
	end
end)
end

--========================================================--
-- FOLLOW LOOP
--========================================================--

local function startFollowing()
if scriptDisabled then return end

if followConnection then
	followConnection:Disconnect()
end

followConnection = RunService.Heartbeat:Connect(function()
	if scriptDisabled then
		if followConnection then followConnection:Disconnect() end
		return
	end

	if panicMode then
		return
	end

	local char = player.Character

	if not char then
		return
	end

	local hrp = char:FindFirstChild("HumanoidRootPart")

	if not hrp then
		return
	end

	updateHitboxes()

	-- ORBIT
	if orbitEnabled
	and orbitTarget
	and orbitTarget.Character
	and orbitTarget.Character:FindFirstChild("HumanoidRootPart") then

		local tHRP = orbitTarget.Character.HumanoidRootPart

		local now = tick()
		local dt = now - lastOrbitTime

		lastOrbitTime = now

		orbitAngle += orbitSpeed * dt

		local x = math.cos(orbitAngle) * ORBIT_RADIUS
		local z = math.sin(orbitAngle) * ORBIT_RADIUS

		hrp.CFrame = CFrame.new(
			tHRP.Position + Vector3.new(
				x,
				FLOAT_HEIGHT,
				z
			)
		)

		doAttack()

		return
	end

	-- ATTACK
	if mode == "attack" and attackTarget then

		local tChar = attackTarget.Character

		if tChar and tChar:FindFirstChild("HumanoidRootPart") then

			local pos =
				tChar.HumanoidRootPart.Position +
				Vector3.new(0,FLOAT_HEIGHT,0)

			smoothMove(hrp, pos)

			doAttack()
		end

		return
	end

	-- IDLE
	if mode == "idle"
	and parentPlayer.Character then

		local pHRP =
			parentPlayer.Character:FindFirstChild("HumanoidRootPart")

		if pHRP then

			smoothMove(
				hrp,
				pHRP.Position + Vector3.new(0,FLOAT_HEIGHT,8)
			)
		end
	end
end)
end

local function stopFollowing()

if followConnection then
	followConnection:Disconnect()
end

followConnection = nil

mode = "stop"
attackTarget = nil
end

--========================================================--
-- DAMAGE PANIC
--========================================================--

local function attachDamageListener()
if scriptDisabled then return end

local char = player.Character

if not char then
	return
end

local humanoid =
	char:FindFirstChildWhichIsA("Humanoid")

if not humanoid then
	return
end

lastHealth = humanoid.Health

humanoid.HealthChanged:Connect(function(newHealth)
	if scriptDisabled then return end

	if newHealth < lastHealth
	and mode == "attack"
	and not panicMode
	and DAMAGE_PANIC_ENABLED then

		panicMode = true

		local startTime = tick()

		local myHRP =
			char:FindFirstChild("HumanoidRootPart")

		local connection

		connection = RunService.Heartbeat:Connect(function()
			if tick() - startTime > 4 or scriptDisabled then
				panicMode = false
				connection:Disconnect()
				return
			end

			if myHRP then

				local randX = math.random(-10,10)
				local randZ = math.random(-10,10)

				myHRP.CFrame = CFrame.new(
					myHRP.Position + Vector3.new(
						randX,
						FLOAT_HEIGHT,
						randZ
					)
				)
			end
		end)
	end

	lastHealth = newHealth
end)
end

--========================================================--
-- COMMAND HANDLER
--========================================================--

local function runCommand(cmd)
if scriptDisabled then return end

if cmd.type == "idle" then

	mode = "idle"

	startFollowing()

	chat("👑🛡️ [XUE] Idling")

elseif cmd.type == "attack" then

	mode = "attack"
	attackTarget = cmd.target

	startFollowing()

	chat("⚔️🔥 [XUE] Hunting "..cmd.target.DisplayName)

elseif cmd.type == "stop" then

	stopFollowing()

	chat("🛑 [XUE] Stopped")

elseif cmd.type == "height" then

	FLOAT_HEIGHT = cmd.val

	chat("📏👑 [XUE] Height = "..cmd.val)

elseif cmd.type == "immune" then

	immunePlayers[cmd.target] = true

	chat("🛡️ [XUE] "..cmd.target.DisplayName.." immune")

elseif cmd.type == "unimmune" then

	immunePlayers[cmd.target] = nil

	chat("⚠️ [XUE] "..cmd.target.DisplayName.." vulnerable")

elseif cmd.type == "block" then

	BLOCK_ENABLED = cmd.val

	chat(cmd.val and
		"🛡️ [XUE] Block ON" or
		"⚔️ [XUE] Block OFF")

elseif cmd.type == "reset" then

	resetUsed = false

	local char = player.Character

	if char and char:FindFirstChild("Humanoid") then
		char.Humanoid.Health = 0
	end

	chat("🔄👑 [XUE] Reset")

elseif cmd.type == "loopkill" then

	mode = "attack"
	attackTarget = cmd.target
	loopKillEnabled = true

	startFollowing()

	chat("⚔️♻️ [XUE] LoopKill "..cmd.target.DisplayName)

elseif cmd.type == "unloopkill" then

	loopKillEnabled = false

	chat("🛑 [XUE] LoopKill OFF")

elseif cmd.type == "orbit" then

	orbitEnabled = cmd.val

	if orbitEnabled then

		orbitTarget = cmd.target

		chat("🌀👑 [XUE] Orbit "..orbitTarget.DisplayName)

	else

		orbitTarget = nil

		chat("🛑 [XUE] Orbit OFF")
	end

elseif cmd.type == "orbitspeed" then

	orbitSpeed = cmd.val

	chat("⚡👑 [XUE] OrbitSpeed "..cmd.val)

elseif cmd.type == "noclip" then

	noclipEnabled = cmd.val

	chat(cmd.val and
		"🟢👑 [XUE] Noclip ON" or
		"🔴👑 [XUE] Noclip OFF")
end
end

